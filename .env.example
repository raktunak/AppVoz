# =============================================================
#  AppVoz — Motor Tutor por Voz (backend FastAPI)
#  Plantilla. Copiar a .env y rellenar los secretos.
# =============================================================

# ----- Base de datos propia (contenedor local pgvector) -----
POSTGRES_USER=appvoz
POSTGRES_PASSWORD=appvoz_dev
POSTGRES_DB=appvoz
DATABASE_URL=postgresql+asyncpg://appvoz:appvoz_dev@db:5432/appvoz

# ----- Google Cloud (Gemini + Vertex + STT/TTS) -----
GCP_PROJECT_ID=brainrot-walloop
GCP_REGION=europe-west1
GOOGLE_API_KEY=

# ----- Embeddings (por Vertex AI: usa los créditos de GCP, sin el free-tier de la API key) -----
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
GCP_EMBEDDINGS_LOCATION=us-central1

# ----- Telnyx (telefonía PSTN/SIP → relay a Gemini Live) -----
# API Key V2 de Telnyx (secreto; NO commitear el valor real).
TELNYX_API_KEY=
# Voice API application ID y subdominio SIP (no secretos).
TELNYX_CONNECTION_ID=
TELNYX_SIP_SUBDOMAIN=

# ----- Agenda (Google Calendar) -----
# ID del calendario donde se crean las citas. Lo sacas de:
#   Google Calendar -> Configuracion del calendario -> Integrar calendario -> "ID de calendario".
# IMPORTANTE (paso humano): ese calendario debe estar COMPARTIDO con el email de la SA
#   appvoz-voice@brainrot-walloop.iam.gserviceaccount.com  con permiso "Hacer cambios en los eventos".
CALENDAR_ID=
AGENDA_TIMEZONE=Europe/Madrid

# ----- Login de alumnos con Google (OAuth 2.0) + Calendar por usuario -----
# Pasos en Google Cloud Console (proyecto brainrot-walloop):
#   1. APIs y servicios -> Pantalla de consentimiento OAuth (tipo External; añade tu correo como
#      "usuario de prueba" mientras esté en modo testing).
#   2. Credenciales -> Crear credenciales -> ID de cliente de OAuth -> Tipo "Aplicación web".
#   3. En "URIs de redireccionamiento autorizados" añade EXACTAMENTE el valor de OAUTH_REDIRECT_URI.
#   4. Habilita "Google Calendar API" en el proyecto.
# Pega aquí el Client ID y el Client Secret. (El secret NO se commitea.)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con lo registrado en la consola. En producción: https://TU-DOMINIO/auth/callback
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
POST_LOGIN_REDIRECT=/4g/
